# ==============================================================================
# WHATSAPP TARGET GROUP
# ==============================================================================
# ID of the specific group (e.g., 120363123456789012@g.us)
# To find this, start the bot, message "!groupid" in the target group, 
# copy the replied ID, paste it here, and restart the bot.
TARGET_GROUP_ID=

# ==============================================================================
# GOOGLE SHEETS SETTINGS
# ==============================================================================
# The ID is the long string in your spreadsheet URL: 
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=

# ==============================================================================
# GOOGLE CLOUD SERVICE ACCOUNT CREDENTIALS
# ==============================================================================
# The email address of the service account you created
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The private key of the service account you created.
# REMEMBER TO KEEP THE BEGIN/END HEADERS and \n newline characters intact!
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
